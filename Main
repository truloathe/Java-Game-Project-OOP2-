import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        Design ds = new Design();

        while (true) {
            GameManager manager = new GameManager(scan);
            manager.start();

            int choice = -1;
            while (true) {
                System.out.println("What would you like to do next?");
                System.out.println("1. Play Again (Choose a new hero)");
                System.out.println("2. Quit Game");
                System.out.println(ds.line1());
                System.out.print("Enter choice [1 - 2]: ");

                if (scan.hasNextInt()) {
                    choice = scan.nextInt();
                    if (choice == 1 || choice == 2) break;
                    else System.out.println(ds.line4() + "\nInvalid selection. Choose 1 or 2\n" + ds.line4());
                } else {
                    System.out.println(ds.line4() + "\nInvalid input. Enter a NUMBER.\n" + ds.line4());
                    scan.next();
                }
            }

            if (choice == 2) {
                System.out.println(ds.line1() + "\nThanks for playing! Goodbye!");
                break;
            }
            System.out.println("\nRestarting game...\n");
        }

        scan.close();
    }
}
