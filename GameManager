import java.util.Scanner;

public class GameManager {

    private Scanner scan;
    private Design ds = new Design();

    public GameManager(Scanner scan) { this.scan = scan; }

    public void start() {
        System.out.println(ds.title());

        Hero[] heroes = HeroFactory.createHeroes();
        int choice = -1;

        while (true) {
            System.out.println("Choose your hero:");
            for (int i = 0; i < heroes.length; i++) System.out.println((i + 1) + ". " + heroes[i].getName());

            System.out.print("Enter choice [1 - " + heroes.length + "]: ");

            if (scan.hasNextInt()) {
                choice = scan.nextInt() - 1;
                if (choice >= 0 && choice < heroes.length) break;
                else System.out.println(ds.line2() + "\nInvalid number. Choose 1-" + heroes.length + "\n" + ds.line2());
            } else {
                System.out.println(ds.line2() + "\nInvalid input. Enter a number 1-" + heroes.length + "\n" + ds.line2());
                scan.next();
            }
        }

        System.out.println(ds.line1());
        Hero player = heroes[choice];

        Enemy enemy = new Enemy("Marco", 120, 35, 25);

        System.out.println("HERO SELECTED: " + player.getName());
        System.out.println(player.getBackstory());
        System.out.println(ds.line1());

        System.out.println("AN ENEMY APPEARS!");
        System.out.println("Enemy: " + enemy.getName());
        System.out.println(enemy.getBackstory());
        System.out.println(ds.line1());

        Game game = new Game(player, enemy, scan);
        game.start();
    }
}
