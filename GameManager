import java.util.Scanner;

public class GameManager {

    private Scanner scan = new Scanner(System.in);
    private Design design = new Design();
    Design ds = new Design();

    public void start() {

        System.out.println(design.title());

        Hero[] heroes = HeroFactory.createHeroes();

        System.out.println("Choose your hero:");

        for (int i = 0; i < heroes.length; i++) {
            System.out.println((i + 1) + ". " + heroes[i].getName());
        }

        int choice = -1;

        while (true) {

            System.out.print("Enter choice [1 - 2]: ");

            if (scan.hasNextInt()) {

                choice = scan.nextInt();

                if (choice >= 1 && choice <= heroes.length) {
                    choice = choice - 1;
                    break;
                } else {
                    System.out.println("Invalid number! Please choose between 1 and 2.");
                }

            } else {
                System.out.println("Invalid input! Numbers only.");
                scan.next();
            }
        }

        System.out.println(ds.line1());

        Hero player = heroes[choice];

        Enemy enemy = new Enemy("Enemy Bot", 120, 35, 25);

        System.out.println("HERO SELECTED: " + player.getName());
        System.out.println(player.getBackstory());
        System.out.println(ds.line1());

        Game game = new Game(player, enemy);
        game.start();
    }

}
