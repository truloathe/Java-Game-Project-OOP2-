import java.util.Random;

public abstract class Skill {

    private String name;
    private String description;
    private int min;
    private int max;

    Random rand = new Random();

    public Skill(String name, String desc, int min, int max) {
        this.name = name;
        this.description = desc;
        this.min = min;
        this.max = max;
    }

    public String getName() {
        return name;
    }

    protected int roll() {
        return rand.nextInt(max - min + 1) + min;
    }

    public abstract int execute(Character attacker, Character target);
}
