import java.util.ArrayList;
import java.util.List;
import java.util.Scanner;

public class Game {

    private Character player;
    private Character enemy;
    private Scanner scan = new Scanner(System.in);
    Design ds = new Design();
    private List<String> battleLog = new ArrayList<>();

    public Game(Character player, Character enemy) {
        this.player = player;
        this.enemy = enemy;
    }

    private void showStatus() {
        System.out.println("\n========================");
        System.out.println("BATTLE STATUS");
        System.out.println(player.getName() + " HP: " + player.getHp());
        System.out.println(enemy.getName() + " HP: " + enemy.getHp());
        System.out.println("========================\n");
    }

    private void printBattleLog() {
        System.out.println("\n--- Battle Log ---");
        for (String msg : battleLog) {
            System.out.println(msg);
        }
        System.out.println("-----------------\n");

        battleLog.clear();
    }

    public void start() {

        System.out.println(ds.getBattleIntro());
        System.out.println(ds.line1());

        while (player.isAlive() && enemy.isAlive()) {

            showStatus();

            int choice = -1;
            while (true) {
                System.out.println("Choose skill:");
                player.displaySkills();
                System.out.println(ds.line1());

                System.out.print("Input Choice: ");
                if (scan.hasNextInt()) {
                    choice = scan.nextInt();
                    if (choice >= 1 && choice <= player.getSkillCount()) {
                        System.out.println(ds.line1());
                        break;
                    } else {
                        System.out.println("\nInvalid input. Please choose again.");
                    }
                } else {
                    System.out.println("\nInvalid input. Please choose again.");
                    scan.next();
                }
            }

            int effect = player.useSkill(choice, enemy);
            if (effect < 0) {
                player.heal(-effect);
                battleLog.add(player.getName() + " used " + player.getSkillName(choice) + " and healed " + (-effect) + " HP!");
            } else {
                enemy.takeDamage(effect);
                battleLog.add(player.getName() + " used " + player.getSkillName(choice) + " and dealt " + effect + " damage!");
            }

            printBattleLog();

            if (!enemy.isAlive()) {
                break;
            }

            int enemySkill = 1;
            int eEffect = enemy.useSkill(enemySkill, player);

            if (eEffect < 0) {
                enemy.heal(-eEffect);
                battleLog.add(enemy.getName() + " used " + enemy.getSkillName(enemySkill) + " and healed " + (-eEffect) + " HP!");
            } else {
                player.takeDamage(eEffect);
                battleLog.add(enemy.getName() + " used " + enemy.getSkillName(enemySkill) + " and dealt " + eEffect + " damage!");
            }

            printBattleLog();
        }

        System.out.println(ds.line1());
        System.out.println(ds.endOfBattle());

        if (player.isAlive()) {
            System.out.println(ds.youWin());
        } else {
            System.out.println(ds.youLose());
            System.out.println(ds.defeatedPose());
        }
    }
}
