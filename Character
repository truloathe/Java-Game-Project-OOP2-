import java.util.ArrayList;
import java.util.List;

public abstract class Character {

    private String name;
    private int hp;
    private int atk;
    private int def;
    Design ds = new Design();

    private List<Skill> skills = new ArrayList<>();

    public Character(String name, int hp, int atk, int def) {
        this.name = name;
        this.hp = hp;
        this.atk = atk;
        this.def = def;
    }

    public String getName() {
        return name;
    }
    public int getHp() {
        return hp;
    }

    public boolean isAlive() {
        return hp > 0;
    }

    public void takeDamage(int damage) {
        hp -= Math.max(1, damage - def / 5);
        System.out.println(name + " took damage!");
        System.out.println(ds.line3());
    }

    public void heal(int amount) {
        hp += amount;
        System.out.println(name + " healed!");
        System.out.println(ds.line3());
    }

    public void addSkill(Skill skill) {
        skills.add(skill);
    }

    public void displaySkills() {
        for (int i = 0; i < skills.size(); i++) {
            System.out.println((i + 1) + ". " + skills.get(i).getName());
        }
    }

    public int getSkillCount() {
        return skills.size();
    }

    public int useSkill(int index, Character target) {
        return skills.get(index - 1).execute(this, target);
    }

    public String getSkillName(int index) {
        return skills.get(index - 1).getName();
    }

    public abstract String getBackstory();
}
